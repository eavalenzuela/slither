# Slither agent configuration. Install to /etc/slither/agent.yaml.
# Schema: IMPLEMENTATION.md §3.7. Unknown top-level keys are rejected
# with "did you mean?" suggestions.
#
# Any value here can be overridden at runtime with an env var set in the
# systemd unit (see `SLITHER_*` in agent/internal/config/config.go).
# SIGHUP reloads rules + file-collector include/exclude paths only; other
# fields are startup-fixed.

agent:
  host_id_file: /var/lib/slither/host_id
  log_level: info
  # keystore.tpm opts the agent into Phase 6 #118 PCR-bound TPM
  # sealing. Default false → keystore.AutoSelect picks keyring (@u)
  # → file. When true, AutoSelect probes /dev/tpmrm0 + PCR 7 first;
  # probe failure degrades to the same keyring → file chain rather
  # than blocking boot. Operators switching to TPM also pass --tpm
  # to `slither-agent enroll` so the first seal happens against the
  # right PCR state. See docs/install.md §2.2 + ADR-0038.
  keystore:
    tpm: false

collectors:
  process:
    enabled: true
  file:
    enabled: true
    include_paths:
      - /etc/**
      - /usr/bin/**
      - /usr/sbin/**
      - /root/**
      - /home/**
    exclude_paths:
      - /proc/**
      - /sys/**
  net:
    enabled: true

rules:
  paths:
    - /etc/slither/rules/*.yml

output:
  kind: stdout
