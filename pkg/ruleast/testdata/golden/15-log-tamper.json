{
  "classification": "edge_only",
  "rule": {
    "category": "file_event",
    "condition": "selection",
    "cost": 2,
    "description": "Truncation/removal of common audit logs.",
    "id": "8b7c4d00-0001-4000-8000-00000000000f",
    "level": "high",
    "selections": [
      {
        "fields": [
          {
            "field": "TargetFilename",
            "op": "regex",
            "values": [
              "wtmp$",
              "btmp$",
              "lastlog$",
              "auth\\.log$",
              "secure$"
            ]
          },
          {
            "field": "TargetFilename",
            "op": "startswith",
            "values": [
              "/var/log/"
            ]
          }
        ],
        "name": "selection"
      }
    ],
    "title": "Log tampering"
  }
}
