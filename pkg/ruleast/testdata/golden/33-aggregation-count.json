{
  "ast_version": 2,
  "classification": "edge_only",
  "rule": {
    "aggregation": {
      "function": "count",
      "op": "\u003e",
      "threshold": 5,
      "timeframe_secs": 60
    },
    "category": "process_creation",
    "condition": "selection",
    "cost": 2,
    "description": "Five or more failed sshd auth events from one host inside a minute.",
    "id": "8b7c4d00-0001-4000-8000-000000000021",
    "level": "high",
    "selections": [
      {
        "fields": [
          {
            "field": "CommandLine",
            "op": "contains",
            "values": [
              "auth failure"
            ]
          },
          {
            "field": "Image",
            "op": "endswith",
            "values": [
              "/usr/sbin/sshd"
            ]
          }
        ],
        "name": "selection"
      }
    ],
    "title": "Brute-force ssh login attempts"
  },
  "state_cap": 1024,
  "state_window_secs": 60
}
